{
  "title": "Homelab Overview",
  "uid": "homelab-overview",
  "refresh": "5s",
  "time": { "from": "now-5m", "to": "now" },
  "timepicker": {},
  "schemaVersion": 39,
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "title": "GPU Temperature (°C)",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "custom": { "lineWidth": 2 },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 70 },
            { "color": "red", "value": 85 }
          ]}
        }
      },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
        "expr": "homelab_gpu_temp_celsius",
        "legendFormat": "{{host}} {{name}}",
        "refId": "A"
      }]
    },
    {
      "id": 2,
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "title": "GPU Power Draw (W)",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": { "unit": "watt", "custom": { "lineWidth": 2 } }
      },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
        "expr": "homelab_gpu_power_watts",
        "legendFormat": "{{host}} {{name}}",
        "refId": "A"
      }]
    },
    {
      "id": 3,
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "title": "GPU Memory Usage (%)",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": { "unit": "percent", "min": 0, "max": 100, "custom": { "lineWidth": 2 } }
      },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
        "expr": "homelab_gpu_memory_percent",
        "legendFormat": "{{host}} {{name}}",
        "refId": "A"
      }]
    },
    {
      "id": 4,
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
